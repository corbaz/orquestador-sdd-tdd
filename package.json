{
  "name": "orquestador-sdd-tdd",
  "version": "0.1.0",
  "description": "Paquete global de Pi para guiar un flujo SDD/TDD con comandos, skills y hooks.",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "private": false,
  "scripts": {
    "check": "bun run check:package && bun run test:doctor",
    "check:package": "bun scripts/check-package.ts",
    "test:doctor": "bun scripts/test-doctor.ts"
  },
  "keywords": [
    "pi-package",
    "sdd",
    "tdd",
    "orchestrator"
  ],
  "exports": {
    ".": "./extensions/orchestrator.ts"
  },
  "files": [
    "README.md",
    "docs/",
    "extensions/",
    "skills/",
    "prompts/"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/orchestrator.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
