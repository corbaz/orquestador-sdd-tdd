{
  "name": "orquestador-sdd-tdd",
  "version": "1.6.3",
  "description": "Paquete global de Pi para guiar un flujo SDD/TDD con comandos, skills y hooks.",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "private": false,
  "scripts": {
    "check": "bun run check:package && bun run test:doctor && bun run test:workflow && bun run check:version",
    "check:package": "bun scripts/check-package.ts",
    "check:version": "bun scripts/check-version.ts",
    "install-hooks": "cp scripts/pre-push-hook.sh .git/hooks/pre-push && chmod +x .git/hooks/pre-push",
    "release": "bun scripts/release.ts",
    "test:doctor": "bun scripts/test-doctor.ts",
    "test:workflow": "bun scripts/test-workflow.ts"
  },
  "keywords": [
    "pi-package",
    "sdd",
    "tdd",
    "orchestrator"
  ],
  "exports": {
    ".": "./extensions/orchestrator.ts"
  },
  "files": [
    "README.md",
    "docs/",
    "extensions/",
    "skills/",
    "prompts/"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "pi": {
    "extensions": [
      "./extensions/orchestrator.ts"
    ],
    "skills": [
      "./skills"
    ]
  }
}
